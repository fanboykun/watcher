{
  "environment": "production",
  "github_token": "",
  "log_dir": "D:\\apps\\watcher\\logs",
  "nssm_path": "C:\\ProgramData\\chocolatey\\bin\\nssm.exe",

  "watchers": [
    {
      "name": "simple",
      "service_name": "simple",
      "metadata_url": "https://github.com/yourorg/repo/releases/latest/download/version.json",
      "check_interval_sec": 30,
      "install_dir": "D:\\apps\\simple",
      "health_check": {
        "enabled": true,
        "retries": 10,
        "interval_sec": 3,
        "timeout_sec": 5
      },
      "services": [
        {
          "windows_service_name": "simple-web-1",
          "binary_name": "simple.exe",
          "env_file": "D:\\apps\\simple\\.env.web.1",
          "health_check_url": "http://localhost:3009/health"
        }
      ]
    }
  ]
}
