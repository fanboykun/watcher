# Watcher Agent Configuration
# Copy this file to .env and fill in your values.

# Server identity (informational)
ENVIRONMENT=production

# GitHub PAT with repo scope (required for private repos)
GITHUB_TOKEN=ghp_your_personal_access_token_here

# Paths
LOG_DIR=D:\apps\watcher\logs
NSSM_PATH=C:\ProgramData\chocolatey\bin\nssm.exe
DB_PATH=D:\apps\watcher\watcher.db

# API server
API_PORT=8080
