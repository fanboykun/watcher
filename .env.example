# Watcher Agent environment configuration
# Copy this file to .env and fill in your values.

# Label for this environment (informational only)
ENVIRONMENT=production

# GitHub Personal Access Token (PAT)
# Required for private repos (scope: repo or contents:read)
# Leave empty for public repos
GITHUB_TOKEN=

# Directory for agent log files
LOG_DIR=D:\apps\watcher\logs

# Path to NSSM executable (installed by install-watcher.ps1)
NSSM_PATH=C:\ProgramData\chocolatey\bin\nssm.exe

# SQLite database file path
DB_PATH=D:\apps\watcher\watcher.db

# API server port (dashboard + REST API)
API_PORT=8080
